# skills-hub environment configuration
# Copy to .env and fill in your values

# Server
PORT=8080
RUST_LOG=skills_hub=debug,tower_http=info

# Database
DATABASE_URL=postgres://skills_hub:skills_hub_dev@localhost:5432/skills_hub

# Redis
REDIS_URL=redis://localhost:6379

# S3-compatible object storage (MinIO for local dev)
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin123
S3_BUCKET=skills-hub
S3_REGION=us-east-1

# Auth
JWT_SECRET=dev-secret-change-in-production

# ── CLI convenience ───────────────────────────────────────────────────────────
# Set these to skip --server / --token flags when using the CLI locally
SKILLS_HUB_URL=http://localhost:8080
# SKILLS_HUB_TOKEN=<paste-your-jwt-token-here>

